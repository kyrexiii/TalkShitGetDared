{
  "name": "talkshitgetdared",
  "version": "1.0.9",
  "description": "The truth will hurt. An open-source cursed-core engine for Truth & Dare prompts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "talkshitgetdared": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "ts-node scripts/generate-data-exports.ts",
    "build": "node scripts/build.js",
    "start": "npm run build && node dist/test.js",
    "dev": "ts-node src/test.ts",
    "pretest": "ts-node scripts/generate-data-exports.ts",
    "test": "jest",
    "lint": "eslint src/"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kyrexiii/TalkShitGetDared"
  },
  "homepage": "https://github.com/kyrexiii/TalkShitGetDared#readme",
  "bugs": {
    "url": "https://github.com/kyrexiii/TalkShitGetDared/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "truth-or-dare",
    "prompts",
    "chaos",
    "nsfw",
    "sfw",
    "typescript",
    "party",
    "discord-bot",
    "hinglish"
  ],
  "author": "Haruka",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
